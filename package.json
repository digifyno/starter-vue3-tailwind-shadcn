    "@vitest/coverage-v8": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.0",
    "vitest-axe": "^0.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.0"
